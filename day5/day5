## FIND SUM OF EACH SUBTREE AND RETURN TREE SUM INTO ROOT->DATA

  #include <bits/stdc++.h>
using namespace std;

class Node
{
public:
    int data;
    Node *left;
    Node *right;

    Node(int val)
    {
        data = val;
        left = right = NULL;
    }
};
static int idx = -1;

// creation of binary tree
Node *buildTree(vector<int> preorder)
{
    idx++;
    if (preorder[idx] == -1)
        return NULL;
    // base case
    Node *root = new Node(preorder[idx]);

    root->left = buildTree(preorder);
    root->right = buildTree(preorder);

    return root;
}

int sumTree(Node *root)
{
    if (root == NULL) return 0;
    int leftcount = sumTree(root->left);
    int rightcount = sumTree(root->right);
    root->data += leftcount+rightcount;
    return root->data;
}

int main()
{
    vector<int> preorder = {1, 2, -1, -1, 3, 4, -1, -1, 5, -1, -1};
    Node *root = buildTree(preorder);
    cout<<sumTree(root)<<endl;
    
    return 0;
}
